// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. NEXTAUTH KÖTELEZŐ MODELLEK (Adminoknak)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user", "admin", "superadmin"
  accounts      Account[]
  sessions      Session[]
  
  // ITT TÖRÖLTÜK A KAPCSOLATOT A SZAVAZATOKKAL
  // votes         Vote[]    
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. A MI SAJÁT MODELLJEINK
// ==========================================

// Kategóriák / Kérdések
model Category {
  id        String   @id @default(cuid())
  name      String   
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  votes     Vote[]   
}

// Szavazatok
model Vote {
  id         String   @id @default(cuid())
  answer     String   
  createdAt  DateTime @default(now())

  // ITT A MEGOLDÁS: A userId most már csak egy sima szöveg (String).
  // Nincs @relation a User táblához! Így bemehet a "guest_..." azonosító is.
  userId     String

  // A kategória kapcsolat marad, mert annak léteznie kell!
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // BIZTONSÁG: Egy azonosító (IP vagy Admin) egy kategóriában csak EGYSZER szavazhat!
  @@unique([userId, categoryId])
}

// Globális beállítások
model Setting {
  id               String  @id @default(cuid())
  isVotingOpen     Boolean @default(true)
  areResultsPublic Boolean @default(false)
}