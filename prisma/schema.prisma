// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. NEXTAUTH KÖTELEZŐ MODELLEK (Google Login)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user", "admin", "superadmin"
  accounts      Account[]
  sessions      Session[]
  votes         Vote[]    // Egy felhasználónak több szavazata is lehet
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. A MI SAJÁT MODELLJEINK
// ==========================================

// Kategóriák / Kérdések
model Category {
  id        String   @id @default(cuid())
  name      String   // Maga a kérdés (pl. "Ki a legviccesebb?")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  votes     Vote[]   // A kategóriához tartozó összes szavazat
}

// Szavazatok (Szabadszöveges válaszok)
model Vote {
  id         String   @id @default(cuid())
  answer     String   // Amit a felhasználó bepötyög! (pl. "Kovács Béla")
  createdAt  DateTime @default(now())

  // Kapcsolat a felhasználóval (Ki szavazott?)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Kapcsolat a kategóriával (Melyik kérdésre?)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // BIZTONSÁG: Egy felhasználó egy kategóriában csak EGYSZER szavazhat!
  @@unique([userId, categoryId])
}

// Globális beállítások (Főkapcsoló az Adminnak)
model Setting {
  id           String  @id @default(cuid())
  isVotingOpen Boolean @default(true)
  areResultsPublic Boolean @default(false)
}